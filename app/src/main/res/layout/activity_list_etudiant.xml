<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tv_list_titre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Liste des Étudiants"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TableLayout
                android:id="@+id/tl_list_etudiants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*">

                <TableRow android:id="@+id/tr_list_header" android:background="@color/black" android:padding="10dp">
                    <TextView android:text="ID" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:text="Nom" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:text="Prénom" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:text="Actions" android:textColor="@color/white" android:textStyle="bold" android:gravity="center"/>
                </TableRow>
            </TableLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>